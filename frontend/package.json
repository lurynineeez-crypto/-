{
  "name": "plant-cabin-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ../node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node ../node_modules/vue-tsc/bin/vue-tsc.js -b && node ../node_modules/vite/bin/vite.js build",
    "preview": "node ../node_modules/vite/bin/vite.js preview --host 0.0.0.0",
    "typecheck": "node ../node_modules/vue-tsc/bin/vue-tsc.js -b --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "echarts": "^5.6.0",
    "lucide-vue-next": "^0.468.0",
    "socket.io-client": "^4.8.1",
    "three": "^0.171.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/three": "^0.171.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
